{
  "name": "pi-trust-defer",
  "version": "1.2.2",
  "description": "Skip the startup trust prompt in pi — auto-decline project trust so you're immediately interactive, then /trust + /reload when ready",
  "type": "module",
  "author": "Tom X Nguyen",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/monotykamary/pi-trust-defer.git"
  },
  "homepage": "https://github.com/monotykamary/pi-trust-defer#readme",
  "bugs": {
    "url": "https://github.com/monotykamary/pi-trust-defer/issues"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding-agent",
    "extension",
    "trust",
    "defer",
    "startup",
    "prompt",
    "interactive",
    "auto-trust"
  ],
  "files": [
    "*.ts",
    "README.md"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint:dead": "knip --no-gitignore"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.79.8",
    "@types/node": "25.9.1",
    "@vitest/coverage-v8": "4.1.7",
    "knip": "6.14.1",
    "typescript": "6.0.3",
    "vitest": "4.1.7"
  },
  "pi": {
    "extensions": [
      "./trust-defer.ts"
    ]
  },
  "overrides": {
    "brace-expansion": "5.0.6"
  },
  "packageManager": "pnpm@11.6.0"
}
